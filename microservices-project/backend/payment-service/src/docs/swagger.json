{
  "openapi": "3.0.0",
  "info": {
    "title": "Payment Service API",
    "version": "1.0.0",
    "description": "Processamento de transações e pagamentos"
  },
  "servers": [
    {
      "url": "http://localhost:3004",
      "description": "Servidor local"
    }
  ],
  "paths": {
    "/payment/process": {
      "post": {
        "summary": "Processa um novo pagamento",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["orderId", "amount", "paymentMethod"],
                "properties": {
                  "orderId": { "type": "string", "example": "uuid-do-pedido" },
                  "amount": { "type": "number", "example": 99.90 },
                  "paymentMethod": { "type": "string", "example": "CREDIT_CARD" },
                  "cardNumber": { "type": "string", "example": "4111111111111111" }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Pagamento processado com sucesso" },
          "402": { "description": "Pagamento recusado" },
          "400": { "description": "Dados inválidos" }
        }
      }
    },
    "/payment/status/{orderId}": {
      "get": {
        "summary": "Consulta o status de um pagamento pelo orderId",
        "parameters": [
          { "name": "orderId", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "responses": {
          "200": { "description": "Sucesso" },
          "404": { "description": "Pagamento não encontrado" }
        }
      }
    }
  }
}